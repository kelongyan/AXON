# AgentFlow local development settings

AGENTFLOW_ENVIRONMENT=development
AGENTFLOW_CHECK_DEPENDENCIES=true
AGENTFLOW_CORS_ALLOWED_ORIGINS=http://localhost:5180

AGENTFLOW_DATABASE_URL=postgresql+psycopg://agentflow:agentflow@localhost:5432/agentflow
AGENTFLOW_REDIS_URL=redis://localhost:6379/0
AGENTFLOW_WORKER_ID=worker-local-1
AGENTFLOW_WORKER_POLL_INTERVAL_SECONDS=30
AGENTFLOW_WORKER_LEASE_SECONDS=60
AGENTFLOW_WORKER_MAX_RUNS_PER_CYCLE=10

AGENTFLOW_MINIO_ENDPOINT_URL=http://localhost:9000
AGENTFLOW_MINIO_ACCESS_KEY=agentflow
AGENTFLOW_MINIO_SECRET_KEY=agentflowsecret
AGENTFLOW_MINIO_BUCKET=agentflow-artifacts

# Optional in development, required outside development.
AGENTFLOW_API_AUTH_KEY=

# Current stage is API-only for model access.
# Do not configure local model paths, GPU runtimes, or local inference services.
AGENTFLOW_LLM_API_BASE_URL=https://api.openai.com/v1
AGENTFLOW_LLM_API_KEY=
AGENTFLOW_LLM_MODEL=gpt-4.1-mini
AGENTFLOW_EMBEDDING_API_BASE_URL=
AGENTFLOW_EMBEDDING_API_KEY=
AGENTFLOW_EMBEDDING_MODEL=text-embedding-3-small
AGENTFLOW_MODEL_REQUEST_TIMEOUT_SECONDS=60

# Browser requests use the Next.js same-origin proxy by default.
# These values are read server-side by the web app; do not expose auth keys as NEXT_PUBLIC_*.
AGENTFLOW_API_BASE_URL=http://localhost:8000
AGENTFLOW_CONSOLE_WORKSPACE_SLUG=
AGENTFLOW_CONSOLE_WORKSPACE_NAME=
AGENTFLOW_CONSOLE_USER_EMAIL=
AGENTFLOW_CONSOLE_USER_NAME=
